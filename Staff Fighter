local player = game.Players.LocalPlayer
local char = player.Character
local mouse = player:GetMouse()

local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

--// FIND STAFF (FIXED)
local function getStaff()
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("Accessory") then
            local handle = v:FindFirstChild("Handle")
            if handle then
                local mesh = handle:FindFirstChildOfClass("SpecialMesh") or handle:FindFirstChildOfClass("Mesh")
                if mesh and mesh.MeshId == "rbxassetid://4146870364" then
                    return handle
                end
            end
        end
    end
end

local staff = getStaff()
if not staff then
    warn("STAFF NOT FOUND")
    return
end

local root = char:WaitForChild("HumanoidRootPart")

--// STATE
local attacking = false
local debounce = false
local combo = 0
local angle = 0

--// DAMAGE FUNCTION
local function damage(hit, dmg)
    if debounce then return end
    local hum = hit.Parent:FindFirstChild("Humanoid")
    if hum and hit.Parent ~= char then
        debounce = true
        hum:TakeDamage(dmg)
        task.wait(0.25)
        debounce = false
    end
end

staff.Touched:Connect(function(hit)
    if attacking then
        damage(hit, 10)
    end
end)

--// CLICK COMBO
mouse.Button1Down:Connect(function()
    attacking = true
    combo += 1
    if combo > 3 then combo = 1 end
end)

mouse.Button1Up:Connect(function()
    attacking = false
end)

--// KEYBINDS
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    -- Z: SPIN
    if input.KeyCode == Enum.KeyCode.Z then
        attacking = true
        for i = 1,20 do
            staff.CFrame = root.CFrame * CFrame.Angles(0, math.rad(i*40), 0) * CFrame.new(2,0,0)
            task.wait()
        end
        attacking = false
    end

    -- X: SLAM
    if input.KeyCode == Enum.KeyCode.X then
        attacking = true
        for i = 1,10 do
            staff.CFrame = root.CFrame * CFrame.new(0, 3 - i*0.4, -2)
            task.wait()
        end
        attacking = false
    end

    -- C: DASH
    if input.KeyCode == Enum.KeyCode.C then
        attacking = true
        for i = 1,8 do
            root.CFrame = root.CFrame * CFrame.new(0,0,-3)
            task.wait()
        end
        attacking = false
    end

    -- R: HEAVY SWING
    if input.KeyCode == Enum.KeyCode.R then
        attacking = true
        for i = 1,15 do
            staff.CFrame = root.CFrame * CFrame.Angles(0,0,math.rad(i*25)) * CFrame.new(2,0,0)
            task.wait()
        end
        attacking = false
    end

    -- F: BLOCK
    if input.KeyCode == Enum.KeyCode.F then
        staff.CFrame = root.CFrame * CFrame.new(0,0,-2)
    end

    -- G: THROW
    if input.KeyCode == Enum.KeyCode.G then
        attacking = true
        local original = staff.CFrame

        for i = 1,15 do
            staff.CFrame = root.CFrame * CFrame.new(0,0,-i*2)
            task.wait()
        end

        for i = 15,1,-1 do
            staff.CFrame = root.CFrame * CFrame.new(0,0,-i*2)
            task.wait()
        end

        staff.CFrame = original
        attacking = false
    end
end)

--// IDLE + SWING LOOP
RS.RenderStepped:Connect(function()
    if not staff then return end

    if attacking then
        angle += 0.25
        staff.CFrame = root.CFrame 
            * CFrame.new(1.5, 0, 0)
            * CFrame.Angles(0, 0, math.sin(angle)*2)
    else
        staff.CFrame = root.CFrame * CFrame.new(1.5, 0, 0)
    end
end)
